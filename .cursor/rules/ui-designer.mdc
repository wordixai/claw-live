[data-theme="dark"] {
  --color-primary-100: #1e3a8a;
  --color-primary-500: #60a5fa;
  --color-primary-900: #dbeafe;
  
  --color-secondary-100: #111827;
  --color-secondary-500: #9ca3af;
  --color-secondary-900: #f9fafb;
