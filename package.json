{
  "name": "openclaw-assist",
  "version": "0.2.0",
  "description": "Remote assist plugin for OpenClaw Control UI — one-click screen sharing with chat for troubleshooting and collaboration.",
  "main": "src/index.ts",
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "inject": "bash scripts/inject.sh",
    "build": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "remote-assist",
    "screen-sharing",
    "collaboration"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "agora-token": "^2.0.5",
    "ws": "^8.19.0"
  }
}
